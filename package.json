{
  "name": "learn-flow-ai",
  "description": "Upload large local files to Google NotebookLM and export study artifacts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:browser": "node scripts/dev-browser.mjs",
    "dev:firefox": "wxt -b firefox",
